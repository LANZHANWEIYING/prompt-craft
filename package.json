{
  "name": "prompt-craft",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "lint": "eslint --ext .js,.vue src --fix",
    "format": "prettier --write src/**/*.{js,vue,css,json}",
    "check": "npm run lint && npm run format",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "axios": "^1.15.1",
    "element-plus": "^2.13.7",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vuedraggable": "^2.24.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^9.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.33.0",
    "prettier": "^3.8.3",
    "vite": "^8.0.9",
    "wrangler": "^4.85.0"
  }
}
